# Server
PORT=3001

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=password
DB_DATABASE=code_league

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_REFRESH_SECRET=change_this_to_another_long_random_refresh_secret
# Окремий секрет для pending-токенів верифікації пошти.
# Якщо не задати — використається JWT_SECRET + ":pending".
JWT_PENDING_SECRET=change_this_to_yet_another_long_random_secret

# ────────────────────────────────────────────────────────────
# Email / SMTP — для відправки коду підтвердження пошти.
# Gmail приклад:
#   1. Увімкніть 2-Step Verification у Google Account
#   2. Створіть App Password: https://myaccount.google.com/apppasswords
#   3. Цей пароль (16 символів без пробілів) ставимо в SMTP_PASS
# ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_gmail_app_password
MAIL_FROM=your.email@gmail.com
MAIL_FROM_NAME=Code League
MAIL_APP_NAME=Code League

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:3000

# Google OAuth
# Get credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Discord OAuth
# Get credentials at: https://discord.com/developers/applications
# Redirect URI: http://localhost:3001/api/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:3001/api/auth/discord/callback

# Contact Form (POST /api/contact)
# Supported values: Discord | Telegram | Webhook
CONTACT_METHOD=Discord
WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXX/XXXXXXXX
