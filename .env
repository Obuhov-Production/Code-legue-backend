# Server
PORT=3001

# Debug mode — logs all HTTP requests/responses in console (dev only)
DEBUG_MODE=true

# Tournament status transitions
# true  — будь-який перехід між статусами дозволено (зручно для тестування/адміну)
# false — тільки дозволені переходи: draft→registration→running→finished
ALLOW_WRITE_TOURNAMENT_STATUS=true

# Seed control
# Set SEED_ENABLED=false to disable ALL seeding on startup
SEED_ENABLED=false
# Set SEED_TOURNAMENTS=false to skip demo tournament creation (admin user still seeded)
SEED_TOURNAMENTS=false

# Seed admin user (created automatically on first start if not exists)
SEED_ADMIN_EMAIL=admin@codeleague.com
SEED_ADMIN_PASSWORD=admin123!
SEED_ADMIN_USERNAME=admin

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=password
DB_DATABASE=code_league

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_REFRESH_SECRET=change_this_to_another_long_random_refresh_secret

# Окремий секрет для pending-токенів верифікації пошти.
# Якщо не задати — використається JWT_SECRET + ":pending".
JWT_PENDING_SECRET=change_this_to_yet_another_long_random_secret

# ────────────────────────────────────────────────────────────
# Email / SMTP — для відправки коду підтвердження пошти.
# Gmail приклад:
#   1. Увімкніть 2-Step Verification у Google Account
#   2. Створіть App Password: https://myaccount.google.com/apppasswords
#   3. Цей пароль (16 символів без пробілів) ставимо в SMTP_PASS
# ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=kostabersov@gmail.com
# ⚠️ УВАГА: тут НЕ звичайний пароль від акаунту, а 16-символьний "App Password"
# з https://myaccount.google.com/apppasswords (потрібна 2FA на акаунті).
# Звичайний пароль "codeleague.noreply@@" Gmail НЕ ПРИЙМЕ для SMTP.
SMTP_PASS=ycwz yktv mswt oxmo
MAIL_FROM=kostabersov@gmail.com
MAIL_FROM_NAME=Code League
MAIL_APP_NAME=Code League

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:3000

