# Server
PORT=3001

# Debug mode — logs all HTTP requests/responses in console (dev only)
DEBUG_MODE=true

# Seed admin user (created automatically on first start if not exists)
SEED_ADMIN_EMAIL=admin@codeleague.com
SEED_ADMIN_PASSWORD=admin123!
SEED_ADMIN_USERNAME=admin

# Database (SQLite — file stored in db/)
DB_PATH=db/code_league.sqlite

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_REFRESH_SECRET=change_this_to_another_long_random_refresh_secret

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:3000

# Google OAuth
# Get credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3001/api/auth/google/callback
